# .env.example — Environment variables for local MWAA development.
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — never commit it. It holds real AWS credentials
# that must stay off Git history.
#
# For production MWAA, these values come from the IAM (Identity and Access
# Management) execution role attached to the MWAA environment. You only need
# this file for local development with the aws-mwaa-local-runner.

# ---------------------------------------------------------------------------
# AWS credentials
# ---------------------------------------------------------------------------
# Use credentials for the dev-admin, staging-admin, or prod-admin profile
# (whichever environment you want to target locally).
#
# Option A — long-lived IAM user keys (dev only, not recommended for staging/prod):
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# Option B — temporary credentials from AWS SSO (Single Sign-On) or assume-role.
# Run: aws sso login --profile dev-admin
# Then: aws sts get-session-token (or use the SSO token directly)
# Uncomment the line below when using temporary credentials:
# AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN

# ---------------------------------------------------------------------------
# AWS region
# ---------------------------------------------------------------------------
# EDP infrastructure lives in eu-central-1 (Frankfurt).
AWS_DEFAULT_REGION=eu-central-1

# ---------------------------------------------------------------------------
# Environment selector
# ---------------------------------------------------------------------------
# Controls which Glue jobs and S3 buckets the DAG targets.
# Acceptable values: dev, staging, prod
# Use dev for all local testing.
MWAA_ENV=dev

# ---------------------------------------------------------------------------
# AWS account ID
# ---------------------------------------------------------------------------
# 12-digit AWS account ID. Used to construct S3 bucket names that follow the
# edp-{env}-{account_id}-{type} naming convention.
# Find yours with: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=158311564771
